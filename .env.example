# ========================================
# ZINA Cantine BAD - Environment Configuration
# ========================================

# Application Configuration
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production
APP_NAME=ZINA Cantine BAD
APP_VERSION=2.0.0

# Database Configuration
DATABASE_URL=postgresql://zina_user:password@localhost:5432/zina_db
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zina_db

# Supabase Configuration
SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your-redis-password

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=noreply@zina-cantine.ci

# Payment Configuration
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Orange Money Configuration
ORANGE_MONEY_API_KEY=your-orange-money-api-key
ORANGE_MONEY_SECRET=your-orange-money-secret
ORANGE_MONEY_ENVIRONMENT=sandbox

# MTN Mobile Money Configuration
MTN_MOBILE_API_KEY=your-mtn-mobile-api-key
MTN_MOBILE_SECRET=your-mtn-mobile-secret
MTN_MOBILE_ENVIRONMENT=sandbox

# SMS Configuration
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+225000000000

# Social Media Configuration
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token

# Google Services
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX

# Cloud Storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=zina-cantine-bad
AWS_REGION=us-east-1

# Monitoring and Logging
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Security
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Rate Limiting
RATELIMIT_STORAGE_URL=redis://localhost:6379/1
RATELIMIT_DEFAULT=100/hour

# Cache Configuration
CACHE_TYPE=redis
CACHE_REDIS_URL=redis://localhost:6379/2
CACHE_DEFAULT_TIMEOUT=300

# Session Configuration
SESSION_TYPE=redis
SESSION_REDIS_URL=redis://localhost:6379/3
SESSION_PERMANENT=false
SESSION_USE_SIGNER=true

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/4
CELERY_RESULT_BACKEND=redis://localhost:6379/5
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json

# File Upload Configuration
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216  # 16MB
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://zina-cantine.ci

# API Configuration
API_VERSION=v1
API_PREFIX=/api
API_TITLE=ZINA Cantine BAD API
API_DESCRIPTION=Professional restaurant management system API

# Development Configuration
TESTING=false
DEBUG_TB_ENABLED=false
DEBUG_TB_INTERCEPT_REDIRECTS=false

# Production Configuration
PRODUCTION=false
SSL_DISABLE=true
SSL_CERT_PATH=certs/cert.pem
SSL_KEY_PATH=certs/key.pem

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE=local

# Analytics Configuration
ANALYTICS_ENABLED=true
ANALYTICS_STORAGE=database
ANALYTICS_RETENTION_DAYS=365

# Notification Configuration
NOTIFICATION_ENABLED=true
NOTIFICATION_CHANNELS=email,sms,push
NOTIFICATION_BATCH_SIZE=100

# Feature Flags
FEATURE_QR_CODE_LOGIN=true
FEATURE_MOBILE_APP=true
FEATURE_DELIVERY=false
FEATURE_RESERVATION=true
FEATURE_CATERING=true
FEATURE_LOYALTY_PROGRAM=true

# Localization
DEFAULT_LANGUAGE=fr
SUPPORTED_LANGUAGES=fr,en
TIMEZONE=Africa/Abidjan
CURRENCY=XOF

# Business Configuration
BUSINESS_NAME=ZINA Cantine BAD
BUSINESS_EMAIL=contact@zina-cantine.ci
BUSINESS_PHONE=+225 27 20 00 00 00
BUSINESS_ADDRESS=Cantine BAD, Abidjan, Côte d'Ivoire
BUSINESS_HOURS=08:00-18:00

# Legal Configuration
PRIVACY_POLICY_URL=https://zina-cantine.ci/privacy
TERMS_OF_SERVICE_URL=https://zina-cantine.ci/terms
COOKIE_POLICY_URL=https://zina-cantine.ci/cookies

# Social Links
FACEBOOK_URL=https://facebook.com/zina-cantine
TWITTER_URL=https://twitter.com/zina-cantine
INSTAGRAM_URL=https://instagram.com/zina-cantine
LINKEDIN_URL=https://linkedin.com/company/zina-cantine

# Development Tools
ENABLE_PROFILING=false
ENABLE_DEBUG_TOOLBAR=false
ENABLE_SQL_DEBUG=false

# Performance
ENABLE_COMPRESSION=true
ENABLE_MINIFICATION=false
ENABLE_CDN=false

# Security Headers
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=31536000
SECURE_CONTENT_TYPE_NOSNIFF=true
SECURE_BROWSER_XSS_FILTER=true
X_FRAME_OPTIONS=DENY

# Database Pool
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_POOL_TIMEOUT=20
SQLALCHEMY_POOL_RECYCLE=3600
SQLALCHEMY_MAX_OVERFLOW=20

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=true
GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin

# Logging Configuration
LOG_FORMAT=%(asctime)s %(levelname)s %(name)s %(message)s
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S
LOG_FILE_MAX_BYTES=10485760  # 10MB
LOG_FILE_BACKUP_COUNT=5

# Error Handling
ERROR_404_HELP=true
ERROR_INCLUDE_MESSAGE=true
PROPAGATE_EXCEPTIONS=true

# Testing Configuration
TEST_DATABASE_URL=sqlite:///test.db
TEST_REDIS_URL=redis://localhost:6379/15

# CI/CD Configuration
CI=false
BUILD_NUMBER=local
GIT_COMMIT=local
GIT_BRANCH=local
